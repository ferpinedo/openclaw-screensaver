{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Activity Screen",
  "version": "0.1.0",
  "identifier": "com.openclaw.activityscreen",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "OpenClaw Activity Screen",
        "useHttpsScheme": false,
        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "visible": true,
        "focus": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
